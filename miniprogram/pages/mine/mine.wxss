.page {
  height: 100%;
  background: var(--color-bg);
}

/* ========== 未登录状态 ========== */
.login-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 80rpx;
}
.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1E40AF, #2563EB);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(30, 64, 175, 0.25);
}
.logo-text {
  font-size: 64rpx;
  font-weight: 800;
  color: #FFFFFF;
}
.welcome-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F2937;
  letter-spacing: 4rpx;
}
.welcome-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 10rpx;
  margin-bottom: 48rpx;
}
.login-btn {
  width: 100%;
  background: #10B981;
  color: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}
.login-btn:active {
  opacity: 0.85;
}

/* ========== 个人信息卡片 ========== */
.profile-card {
  margin: 24rpx;
  padding: 28rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, #1E40AF, #1D4ED8);
  color: #FFFFFF;
}
.profile-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255,255,255,0.4);
}
.avatar-text {
  font-size: 40rpx;
  font-weight: 700;
}
.profile-info { flex: 1; }
.profile-name {
  font-size: 34rpx;
  font-weight: 700;
}
.profile-tags {
  display: flex;
  gap: 10rpx;
  margin-top: 10rpx;
}
.tag {
  background: rgba(255,255,255,0.2);
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
}
.profile-arrow {
  font-size: 40rpx;
  opacity: 0.6;
}
.dept-bar {
  margin-top: 20rpx;
  background: rgba(255,255,255,0.12);
  border-radius: 12rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.dept-icon { font-size: 28rpx; }
.dept-text { font-size: 24rpx; }
.dept-name { font-size: 24rpx; font-weight: 700; }

/* ========== 我的年审 ========== */
.section {
  padding: 0 24rpx;
  margin-top: 32rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 16rpx;
  display: block;
}

.review-list { display: flex; flex-direction: column; gap: 12rpx; }
.review-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 22rpx 24rpx;
  border: 1rpx solid #F3F4F6;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.review-card:active { background: #F9FAFB; }
.review-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}
.review-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}
.icon-warn { background: #FEF3C7; }
.icon-success { background: #D1FAE5; }
.icon-error { background: #FEE2E2; }
.review-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1F2937;
  display: block;
}
.review-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 4rpx;
}
.review-reviewer {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-top: 2rpx;
}

/* ========== 盖章指引 ========== */
.guide-card {
  margin-top: 16rpx;
  background: #EFF6FF;
  border: 1rpx solid #BFDBFE;
  border-radius: var(--radius-lg);
  padding: 24rpx;
}
.guide-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}
.guide-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1E40AF;
}
.guide-text {
  font-size: 24rpx;
  color: #1E40AF;
  line-height: 1.6;
  white-space: pre-line;
}

/* ========== 设置 ========== */
.settings-list {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  border: 1rpx solid #F3F4F6;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
}
.setting-item:active { background: #F9FAFB; }
.setting-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
}
.logout-text { color: var(--color-warn-red); }
.setting-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
}
.logout-arrow { color: #FCA5A5; }
.setting-divider {
  height: 1rpx;
  background: #F3F4F6;
  margin-left: 24rpx;
}

/* ========== 底部安全区 ========== */
.bottom-safe { height: 140rpx; }
