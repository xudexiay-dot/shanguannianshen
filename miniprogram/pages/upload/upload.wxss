.page { height: 100%; background: #F3F4F6; padding: 24rpx; }

/* ========== 步骤条 ========== */
.steps { display: flex; align-items: center; justify-content: center; margin-bottom: 28rpx; }
.step { display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.step-dot { width: 44rpx; height: 44rpx; border-radius: 50%; background: #D1D5DB; display: flex; align-items: center; justify-content: center; font-size: 20rpx; color: #9CA3AF; font-weight: 700; }
.dot-active { background: #2563EB; color: #fff; }
.step-line { width: 80rpx; height: 4rpx; background: #D1D5DB; margin: 0 -4rpx 18rpx; }
.line-active { background: #2563EB; }
.step-label { font-size: 20rpx; color: #9CA3AF; }
.label-active { color: #2563EB; font-weight: 700; }

/* ========== 社团名称输入 ========== */
.club-input-card { background: #fff; border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 20rpx; display: flex; align-items: center; gap: 16rpx; }
.club-label { font-size: 26rpx; font-weight: 700; color: #374151; flex-shrink: 0; }
.club-input { flex: 1; height: 72rpx; background: #F9FAFB; border: 1rpx solid #E5E7EB; border-radius: 12rpx; padding: 0 18rpx; font-size: 26rpx; }

/* ========== 上传区 ========== */
.upload-zone { background: #fff; border: 4rpx dashed rgba(37,99,235,0.25); border-radius: 20rpx; display: flex; flex-direction: column; align-items: center; padding: 80rpx 32rpx; }
.upload-zone:active { border-color: rgba(37,99,235,0.5); }
.upload-icon { font-size: 64rpx; margin-bottom: 20rpx; }
.upload-title { font-size: 28rpx; font-weight: 700; color: #374151; }
.upload-hint { font-size: 22rpx; color: #9CA3AF; margin-top: 8rpx; }

/* ========== 文件卡片 ========== */
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; border: 1rpx solid #F3F4F6; }
.file-card { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0; }
.file-left { display: flex; align-items: center; gap: 16rpx; flex: 1; min-width: 0; }
.file-icon { width: 72rpx; height: 72rpx; border-radius: 16rpx; background: #FEE2E2; display: flex; align-items: center; justify-content: center; font-size: 32rpx; flex-shrink: 0; }
.file-name { font-size: 26rpx; font-weight: 700; color: #1F2937; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.file-size { font-size: 22rpx; color: #6B7280; display: block; margin-top: 4rpx; }
.btn-upload { background: #2563EB; color: #fff; font-size: 24rpx; padding: 16rpx 32rpx; border-radius: 12rpx; font-weight: 700; border: none; flex-shrink: 0; }
.badge { font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 9999rpx; font-weight: 700; }
.badge-warning { background: #FEF3C7; color: #92400E; }
.badge-success { background: #D1FAE5; color: #166534; }

/* ========== 批注区域 ========== */
.anno-section-title { font-size: 26rpx; font-weight: 700; color: #DC2626; margin-bottom: 16rpx; }

.anno-card { border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; border-left: 8rpx solid; }
.anno-error { background: #FFF5F5; border-color: #DC2626; }
.anno-warn { background: #FFFBEB; border-color: #F59E0B; }

.anno-head { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.anno-badge { font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 8rpx; color: #fff; font-weight: 700; }
.badge-red { background: #DC2626; }
.badge-yellow { background: #F59E0B; }
.anno-title { font-size: 28rpx; font-weight: 700; color: #1F2937; }

/* 位置 */
.anno-location { display: flex; align-items: center; gap: 8rpx; margin-bottom: 14rpx; background: rgba(0,0,0,0.03); border-radius: 8rpx; padding: 12rpx 16rpx; }
.anno-tag { font-size: 22rpx; font-weight: 700; color: #6B7280; flex-shrink: 0; }
.anno-loc-text { font-size: 22rpx; color: #374151; }

/* 高亮错误 */
.anno-highlight { margin-bottom: 10rpx; padding: 12rpx 16rpx; background: #FECACA; border-radius: 8rpx; }
.anno-highlight .anno-label { font-size: 22rpx; font-weight: 700; color: #991B1B; }
.anno-wrong { font-size: 22rpx; color: #991B1B; text-decoration: line-through; }

/* 正确做法 */
.anno-fix { margin-bottom: 10rpx; padding: 12rpx 16rpx; background: #D1FAE5; border-radius: 8rpx; }
.anno-fix .anno-label { font-size: 22rpx; font-weight: 700; color: #166534; }
.anno-right { font-size: 22rpx; color: #166534; font-weight: 600; }

/* 操作指引 */
.anno-guide { display: flex; gap: 8rpx; padding: 12rpx 16rpx; background: #EFF6FF; border-radius: 8rpx; }
.guide-icon { font-size: 24rpx; flex-shrink: 0; }
.guide-text { font-size: 22rpx; color: #1E40AF; line-height: 1.5; }

/* 全部通过 */
.all-pass { text-align: center; padding: 60rpx 0; }
.pass-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.pass-title { font-size: 34rpx; font-weight: 700; color: #16A34A; display: block; }
.pass-desc { font-size: 24rpx; color: #6B7280; display: block; margin-top: 8rpx; }

/* 操作按钮 */
.action-row { display: flex; gap: 16rpx; margin-top: 28rpx; }
.flex-1 { flex: 1; }
.btn-outline { background: #fff; border: 1rpx solid #D1D5DB; color: #374151; border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; font-weight: 700; }
.btn-primary { background: #2563EB; color: #fff; border-radius: 16rpx; padding: 24rpx; font-size: 28rpx; font-weight: 700; border: none; }

/* ========== 规则速查 ========== */
.rules-card { margin-top: 32rpx; background: #EFF6FF; border: 1rpx solid #BFDBFE; border-radius: 16rpx; padding: 24rpx; }
.rules-title { font-size: 26rpx; font-weight: 700; color: #1E40AF; display: block; margin-bottom: 12rpx; }
.rule-item { font-size: 22rpx; color: #1E40AF; display: block; margin-top: 4rpx; }
.rule-cat { font-weight: 700; font-size: 24rpx; margin-top: 14rpx; }
.rule-warn { color: #DC2626; margin-top: 12rpx; }

.bottom-safe { height: 60rpx; }
