.page {
  height: 100%;
  background: var(--color-bg);
  padding: 24rpx;
}

/* ========== 文档信息头部 ========== */
.review-header { margin-bottom: 24rpx; }
.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.header-info { flex: 1; }
.header-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  display: block;
}
.header-meta {
  font-size: 22rpx;
  color: #6B7280;
  display: block;
  margin-top: 6rpx;
}

/* ========== 时间线 ========== */
.timeline {
  position: relative;
  padding-left: 44rpx;
}
.timeline-node {
  position: relative;
  padding-bottom: 28rpx;
}
.timeline-node:last-child { padding-bottom: 0; }

.node-dot {
  position: absolute;
  left: -44rpx;
  top: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
}
.timeline-node.done .node-dot {
  background: #16A34A;
}
.timeline-node.current .node-dot {
  background: #F59E0B;
}
.node-check {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 700;
}
.node-num {
  font-size: 20rpx;
  color: #FFFFFF;
}
.node-pulse {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

.node-line {
  position: absolute;
  left: -27rpx;
  top: 36rpx;
  bottom: 0;
  width: 3rpx;
  background: #E5E7EB;
}
.line-done { background: #16A34A; }

.node-content {
  margin-left: 8rpx;
}
.timeline-node:not(.done):not(.current) .node-content {
  opacity: 0.45;
}
.node-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1F2937;
  display: block;
}
.node-time {
  font-size: 22rpx;
  color: #6B7280;
  display: block;
  margin-top: 4rpx;
}
.node-desc {
  font-size: 22rpx;
  color: #374151;
  display: inline-block;
  margin-top: 6rpx;
  background: #FFFBEB;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* ========== 批注 ========== */
.annotations { margin-bottom: 24rpx; }
.anno-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1F2937;
  display: block;
  margin-bottom: 20rpx;
}
.anno-list { display: flex; flex-direction: column; gap: 16rpx; }
.anno-item {
  padding: 20rpx;
  border-radius: 12rpx;
}
.anno-error {
  background: #FEF2F2;
  border: 1rpx solid #FECACA;
}
.anno-warn {
  background: #FFFBEB;
  border: 1rpx solid #FDE68A;
}
.anno-label {
  display: inline-block;
  font-size: 20rpx;
  color: #FFFFFF;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.label-error { background: #DC2626; }
.label-warn { background: #F59E0B; }
.anno-title-text {
  font-size: 24rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 4rpx;
}
.anno-error .anno-title-text { color: #991B1B; }
.anno-warn .anno-title-text { color: #92400E; }
.anno-detail {
  font-size: 22rpx;
  display: block;
  margin-bottom: 6rpx;
}
.anno-error .anno-detail { color: #991B1B; }
.anno-warn .anno-detail { color: #92400E; }
.anno-suggestion {
  font-size: 22rpx;
  color: #2563EB;
  display: block;
}

/* ========== 归口盖章 ========== */
.seal-guide {
  background: linear-gradient(135deg, #F0FDF4, #EFF6FF);
  border: 1rpx solid #BBF7D0;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.seal-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  font-size: 28rpx;
}
.seal-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #166534;
}
.seal-text {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
  display: block;
}
.seal-bold {
  font-weight: 700;
  color: #166534;
}
.seal-warn {
  margin-top: 16rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 12rpx;
  padding: 16rpx;
}
.seal-warn-text {
  font-size: 24rpx;
  color: #DC2626;
  font-weight: 700;
}

/* ========== 底部 ========== */
.bottom-safe { height: 60rpx; }
