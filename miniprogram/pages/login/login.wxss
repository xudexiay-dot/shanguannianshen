.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1E40AF 0%, #2563EB 40%, #F3F4F6 40%);
  padding: 0 32rpx;
}

/* ========== 返回 ========== */
.back-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 24rpx 0 0;
}
.back-icon { font-size: 36rpx; color: #FFFFFF; }
.back-text { font-size: 28rpx; color: rgba(255,255,255,0.8); }

/* ========== Hero ========== */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 48rpx;
}
.hero-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid rgba(255,255,255,0.25);
  margin-bottom: 28rpx;
}
.hero-logo-text {
  font-size: 56rpx;
  font-weight: 800;
  color: #FFFFFF;
}
.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 6rpx;
}
.hero-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 10rpx;
}

/* ========== 登录卡片 ========== */
.login-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.1);
}
.card-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}
.card-desc {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  margin-bottom: 40rpx;
}

/* ========== 微信登录按钮 ========== */
.wechat-btn {
  width: 100%;
  background: #10B981;
  color: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
}
.wechat-btn:active { opacity: 0.85; }
.wechat-btn-icon { font-size: 34rpx; }

/* ========== 用户协议 ========== */
.agreement-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 28rpx;
  justify-content: center;
}
.checkbox {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  border: 2rpx solid #D1D5DB;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
}
.checkbox.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}
.check-mark {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 700;
}
.agreement-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}
.link {
  color: var(--color-primary);
  text-decoration: underline;
}

/* ========== 分割线 ========== */
.divider-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 36rpx 0;
}
.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E5E7EB;
}
.divider-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ========== 手机号登录 ========== */
.phone-btn {
  width: 100%;
  background: #FFFFFF;
  color: var(--color-text-primary);
  border: 1rpx solid #D1D5DB;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.phone-btn:active { background: #F9FAFB; }
.phone-icon { font-size: 32rpx; }

/* ========== 注册表单 ========== */
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  display: block;
  font-size: 24rpx;
  color: #374151;
  font-weight: 600;
  margin-bottom: 10rpx;
}
.form-input {
  width: 100%;
  height: 80rpx;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.form-picker {
  width: 100%;
  height: 80rpx;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  font-size: 28rpx;
}
.form-picker .placeholder { color: #9CA3AF; }
.picker-arrow { font-size: 36rpx; color: #D1D5DB; }
.back-login {
  text-align: center;
  margin-top: 24rpx;
  padding: 16rpx;
}

/* ========== 底部 ========== */
.footer-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}
