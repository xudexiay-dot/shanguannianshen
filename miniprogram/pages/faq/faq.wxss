.page {
  height: 100%;
  background: var(--color-bg);
  padding: 24rpx;
}

/* ========== 分类标签 ========== */
.tabs-scroll { margin-bottom: 24rpx; }
.tabs-row {
  display: flex;
  gap: 12rpx;
  padding: 4rpx 0;
  white-space: nowrap;
}
.tab-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  background: #FFFFFF;
  color: #6B7280;
  border: 1rpx solid #E5E7EB;
}
.tab-tag:active { background: #F9FAFB; }
.tab-active {
  background: #2563EB;
  color: #FFFFFF;
  border-color: #2563EB;
}

/* ========== 私章警示 ========== */
.seal-warning {
  background: #FEF2F2;
  border: 4rpx solid #DC2626;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.seal-warn-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}
.seal-warn-icon { font-size: 36rpx; }
.seal-warn-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #991B1B;
}
.seal-warn-list { display: flex; flex-direction: column; gap: 8rpx; }
.seal-warn-item {
  font-size: 24rpx;
  color: #991B1B;
  line-height: 1.5;
}

/* ========== FAQ 卡片 ========== */
.faq-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.faq-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  border: 1rpx solid #F3F4F6;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.faq-danger {
  border-color: #FECACA;
}
.faq-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 24rpx;
  gap: 16rpx;
}
.faq-header:active { background: #F9FAFB; }
.faq-question {
  font-size: 26rpx;
  font-weight: 700;
  color: #1F2937;
  flex: 1;
}
.faq-danger .faq-question { color: #991B1B; }
.faq-arrow {
  font-size: 32rpx;
  color: #D1D5DB;
  transition: transform 0.2s;
  flex-shrink: 0;
}
.arrow-up { transform: rotate(180deg); color: #2563EB; }
.faq-answer {
  padding: 0 24rpx 26rpx;
}
.faq-answer-text {
  font-size: 24rpx;
  color: #4B5563;
  line-height: 1.7;
}
.faq-danger .faq-answer-text { color: #991B1B; }

/* ========== 联系客服 ========== */
.contact-card {
  margin-top: 32rpx;
  background: #EFF6FF;
  border: 1rpx solid #BFDBFE;
  border-radius: var(--radius-lg);
  padding: 36rpx 28rpx;
  text-align: center;
}
.contact-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E40AF;
  display: block;
}
.contact-desc {
  font-size: 24rpx;
  color: #1E40AF;
  display: block;
  margin-top: 8rpx;
  margin-bottom: 28rpx;
}
.btn-contact {
  background: #2563EB;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  padding: 22rpx 48rpx;
  border-radius: 9999rpx;
  border: none;
  display: inline-block;
}
.btn-contact:active { opacity: 0.85; }

/* ========== 底部 ========== */
.bottom-safe { height: 60rpx; }
