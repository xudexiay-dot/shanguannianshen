.page { height: 100%; background: #F3F4F6; padding: 20rpx; }

/* 加载/空状态 */
.loading { text-align: center; padding: 120rpx 0; color: #9CA3AF; font-size: 28rpx; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; font-weight: 700; color: #6B7280; }
.empty-hint { font-size: 24rpx; color: #9CA3AF; margin-top: 10rpx; }

/* 汇总 */
.summary { display: flex; gap: 24rpx; padding: 16rpx 0 20rpx; }
.summary-item { font-size: 24rpx; color: #6B7280; }
.num { font-weight: 700; color: #1F2937; }
.num.green { color: #16A34A; }
.num.orange { color: #F59E0B; }
.btn-export { margin-left: auto; background: #16A34A; color: #fff; font-size: 22rpx; padding: 10rpx 24rpx; border-radius: 9999rpx; font-weight: 700; border: none; line-height: 1.4; }
.btn-export:active { opacity: 0.8; }

/* 表格 */
.table-wrap { width: 100%; overflow-x: auto; border-radius: 12rpx; background: #fff; }
.table { min-width: 900rpx; }
.tr { display: flex; border-bottom: 1rpx solid #F3F4F6; }
.tr.head { background: #1E40AF; border-radius: 12rpx 12rpx 0 0; }
.tr:last-child { border-bottom: none; }
.row-pass { background: #F0FDF4; }
.row-reject { background: #FFF5F5; }

.th, .td { padding: 18rpx 12rpx; font-size: 22rpx; display: flex; align-items: center; }
.th { color: #FFFFFF; font-weight: 700; font-size: 22rpx; }
.td { color: #374151; word-break: break-all; align-items: flex-start; }

.th-club, .td-club { width: 130rpx; flex-shrink: 0; }
.th-ver, .td-ver { width: 70rpx; flex-shrink: 0; }
.th-time, .td-time { width: 170rpx; flex-shrink: 0; }
.th-status, .td-status { width: 110rpx; flex-shrink: 0; }
.th-err, .td-err { flex: 1; min-width: 420rpx; display: flex; flex-direction: column; gap: 4rpx; }
.err-summary { font-size: 22rpx; font-weight: 700; color: #DC2626; display: block; }
.err-item { font-size: 20rpx; color: #991B1B; display: block; line-height: 1.5; }
.err-fix { font-size: 20rpx; color: #2563EB; display: block; line-height: 1.4; margin-bottom: 4rpx; }
.th-pass, .td-pass { width: 170rpx; flex-shrink: 0; }

.status-tag { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 9999rpx; font-weight: 700; }
.tag-pass { background: #D1FAE5; color: #166534; }
.tag-reject { background: #FEE2E2; color: #991B1B; }
.tag-pending { background: #FEF3C7; color: #92400E; }

.bottom-safe { height: 40rpx; }
